<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Example - Application Layout</title>

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Google Fonts - Inter (similar to original) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/files/styles.css">

    <style>
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        }
    </style>
</head>
<body>
    <div class="min-h-screen relative overflow-hidden bg-gradient-to-br from-blue-500 via-blue-600 to-blue-700">
        <%= render "#{app_name}/partials/header" %>

        <!-- Blue gradient overlay - stronger at top, fades in middle -->
        <div class="absolute inset-0 w-full h-full pointer-events-none">
            <div class="absolute inset-0 bg-gradient-to-b from-blue-600/70 via-50% via-blue-500/10 to-transparent"></div>
        </div>

        <!-- White overlay from bottom -->
        <div class="absolute inset-0 w-full h-full pointer-events-none">
            <div class="absolute bottom-0 left-0 right-0 h-3/4 bg-gradient-to-t from-white/90 via-70% via-white/50 to-transparent"></div>
        </div>

        <!-- Content -->
        <div class="relative z-10 pt-24 md:pt-32 pb-20 px-4">
          <%= render "shared/flash" %>
          <%= yield %>
        </div>
    </div>

    <script src="/files/script.js"></script>
</body>
</html>