<% content_for :title, "#{resolve_title_metadata(request.path)}" %>

<div class="bg-white text-gray-800 relative isolate antialiased min-h-screen">
  <div class="hidden pointer-events-none absolute inset-0 -z-10 overflow-hidden">
    <div class="h-[60vh] w-[60vh] rounded-full bg-gradient-to-br absolute -top-32 -left-32 from-neutral-200 via-neutral-100 to-neutral-300 opacity-20 blur-2xl"></div>
    <div class="h-[40vh] w-[50vh] rounded-full bg-gradient-to-tr absolute -bottom-20 right-10 from-neutral-300 via-neutral-200 to-neutral-100 opacity-40 blur-3xl"></div>
    <div class="h-[35vh] w-[45vh] rounded-full bg-gradient-to-b [28vh] absolute top-28 left-1/4 from-neutral-300 via-neutral-200 to-neutral-100 opacity-60 blur-3xl"></div>
  </div>
  <main class="mx-auto px-8 lg:px-0 relative z-20 pt-16">
    <div class="relative lg:py-24 flex items-center py-16 text-center">
      <%#= image_tag 'litetracker/hero-image.webp', width: "2880", height: "1606", class: "absolute inset-0 object-cover w-full h-full opacity-40 object-cover" %>
      <div class="relative space-y-8 w-full lg:px-2">
        <div class="relative mx-auto max-w-7xl lg:pb-16">
          <div class="items-center justify-center px-4 py-2 rounded-full bg-white/70 text-sm inline-flex gap-2 border border-zinc-300/70">
            <svg class="w-4 h-4 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="Windframe_abV5IUrLS">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
            </svg>
            <span class="text-gray-700 font-medium"><%= safe_phrase('litetracker_onboard-hero-badge', 'Limited Time Offer') %></span>
          </div>
          <div class="flex justify-between w-full">
            <div class="space-y-6 lg:w-6/12 lg:text-left">
              <p class="text-5xl font-bold leading-tight lg:text-7xl text-gray-900">
                <%= safe_phrase('litetracker_onboard-hero-header', 'Launch Your Product with $100 Free Credits') %>
              </p>
              <p class="text-xl text-gray-700/80 mx-auto max-w-3xl">
                <%= safe_phrase('litetracker_onboard-hero-subheader', "Join thousands of successful
                launches. Get started today with $100 in platform credits and unlock premium features to accelerate your
                product's growth.") %>
              </p>
            </div>
            <div class="hidden lg:w-5/12 order-2 transform-gpu [transform-style:preserve-3d]">
              <%= image_tag 'litetracker/hero-image.webp', width: "2880", height: "1606", class: "rounded [backface-visibility:hidden] [transform:scale(1)_perspective(1040px)_rotateY(-11deg)_rotateX(2deg)_rotate(2deg)]" %>
            </div>
          </div>
          <div class="hidden lg:block bg-gray-50 lg:absolute -top-20 -right-14 w-[640px] h-[596px] -z-10">
            <svg viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true" class="absolute inset-y-0 left-0 hidden h-full w-30 fill-white lg:block dark:fill-gray-900">
              <polygon points="0,0 90,0 50,100 0,100" />
            </svg>
            <%= image_tag 'litetracker/hero-image.webp', width: "2880", height: "1606", class: "aspect-3/2 object-cover lg:aspect-auto lg:size-full" %>
          </div>
        </div>
        <div class="w-full bg-[#f6f6f8] py-8 z-20">
          <div class="lg:grid-cols-2 mt-12 mx-auto grid gap-6 max-w-4xl">
            <div class="bg-white/70 rounded-2xl text-left border border-zinc-300/70 p-8 space-y-6 hover:shadow-xl transition-shadow">
              <div class="w-12 h-12 rounded-full bg-neutral-900 items-center justify-center flex">
                <svg class="w-6 h-6 text-neutral-100" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="Windframe_FOwIdot2l">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
              </div>
              <div class="space-y-3">
                <p class="text-2xl font-semibold text-gray-900">Submit Your Details</p>
                <p class="text-gray-700/80">
                  <%= safe_phrase('litetracker_onboard-user_details-subheader', 'Fill out a quick form and get instant access to your $100 credits. Start launching within minutes.') %>
                </p>
              </div>
              <form class="space-y-4">
                <div>
                  <label class="text-sm font-medium text-gray-700 mb-2 block">Full Name</label>
                  <input type="text" placeholder="John Doe" class="border border-zinc-300/70 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-neutral-900 w-full px-4 py-3 rounded-lg bg-white text-gray-900">
                </div>
                <div>
                  <label class="text-sm font-medium text-gray-700 mb-2 block">Email Address</label>
                  <input type="email" placeholder="john@example.com" class="border border-zinc-300/70 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-neutral-900 w-full px-4 py-3 rounded-lg bg-white text-gray-900">
                </div>
                <div>
                  <label class="text-sm font-medium text-gray-700 mb-2 block">Company Name</label>
                  <input type="text" placeholder="Acme Inc." class="border border-zinc-300/70 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-neutral-900 w-full px-4 py-3 rounded-lg bg-white text-gray-900">
                </div>
                <button type="submit" class="inline-flex border border-transparent transition-colors hover:bg-neutral-700 w-full items-center justify-center rounded-lg bg-neutral-900 px-6 py-3 font-semibold text-neutral-100">
                  <%= safe_phrase('litetracker_onboard-btn-claim-credits', 'Claim $100 Credits') %>
                </button>
              </form>
            </div>
            <div class="bg-white/70 rounded-2xl text-left border border-zinc-300/70 p-8 space-y-6 hover:shadow-xl transition-shadow">
              <div class="w-12 h-12 rounded-full bg-neutral-900 items-center justify-center flex">
                <svg class="w-6 h-6 text-neutral-100" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="Windframe_rPAouV9qG">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div class="space-y-3">
                <p class="text-2xl font-semibold text-gray-900">Schedule a Call</p>
                <p class="text-gray-700/80">
                  <%= safe_phrase('litetracker_onboard-schedule-subheader', 'Talk to our launch experts and get personalized guidance for your product launch journey.') %>
                </p>
              </div>
              <div class="space-y-4">
                <div class="space-y-3">
                  <div class="items-start rounded-lg bg-white flex gap-3 p-4 border border-zinc-300/50">
                    <svg class="w-5 h-5 text-neutral-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="Windframe_X3rjLJwog">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <div>
                      <p class="font-medium text-gray-900"><%= safe_phrase('litetracker_onboard-schedule-benefit_1-header', 'Personalized Strategy') %></p>
                      <p class="text-sm text-gray-700/80"><%= safe_phrase('litetracker_onboard-schedule-benefit_1-subheader', 'Custom launch plan tailored to your needs') %></p>
                    </div>
                  </div>
                  <div class="items-start rounded-lg bg-white flex gap-3 p-4 border border-zinc-300/50">
                    <svg class="w-5 h-5 text-neutral-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="Windframe_2sOrbxx4m">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <div>
                      <p class="font-medium text-gray-900"><%= safe_phrase('litetracker_onboard-schedule-benefit_2-header', 'Expert Guidance') %></p>
                      <p class="text-sm text-gray-700/80"><%= safe_phrase('litetracker_onboard-schedule-benefit_2-subheader', 'Learn from successful launch veterans') %></p>
                    </div>
                  </div>
                  <div class="items-start rounded-lg bg-white flex gap-3 p-4 border border-zinc-300/50">
                    <svg class="w-5 h-5 text-neutral-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="Windframe_bakZ4WMyg">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <div>
                      <p class="font-medium text-gray-900"><%= safe_phrase('litetracker_onboard-schedule-benefit_3-header', 'Priority Support') %></p>
                      <p class="text-sm text-gray-700/80"><%= safe_phrase('litetracker_onboard-schedule-benefit_3-subheader', 'Get dedicated assistance throughout launch') %></p>
                    </div>
                  </div>
                </div>
                <a href="#" class="inline-flex border border-zinc-300/70 transition-colors hover:bg-black/5 w-full items-center justify-center rounded-lg bg-white/70 px-6 py-3 font-semibold" data-cal-link="neshaz/litetracker" data-cal-namespace="litetracker" data-cal-config='{"layout":"month_view"}'>
                  Schedule Free Call
                </a>
              </div>
            </div>
          </div>
        </div>
        <div class="items-center justify-center pt-12 flex gap-12 flex-wrap">
          <div class="text-center">
            <div class="text-3xl font-bold text-gray-900"><%= safe_phrase('litetracker_onboard-info-1-value', '$100') %></div>
            <div class="text-sm text-gray-700/80"><%= safe_phrase('litetracker_onboard-info-1-info', 'Free Credits') %></div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-gray-900"><%= safe_phrase('litetracker_onboard-info-2-value', '10K+') %></div>
            <div class="text-sm text-gray-700/80"><%= safe_phrase('litetracker_onboard-info-2-info', 'Successful Launches') %></div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-gray-900"><%= safe_phrase('litetracker_onboard-info-3-value', '24/7') %></div>
            <div class="text-sm text-gray-700/80"><%= safe_phrase('litetracker_onboard-info-3-info', 'Support Available') %></div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-gray-900"><%= safe_phrase('litetracker_onboard-info-4-value', '98%') %></div>
            <div class="text-sm text-gray-700/80"><%= safe_phrase('litetracker_onboard-info-4-info', 'Satisfaction Rate') %></div>
          </div>
        </div>
      </div>
    </div>
    <section class="py-16 border-t border-zinc-300/70">
      <div class="mx-auto max-w-6xl">
        <div class="text-center mb-12">
          <p class="text-3xl font-bold text-gray-900 mb-4"><%= safe_phrase('litetracker_onboard-whats_included-header', "What's Included with Your Credits") %></p>
          <p class="text-lg text-gray-700/80"><%= safe_phrase('litetracker_onboard-whats_included-subheader', "Everything you need to launch successfully") %></p>
        </div>
        <div class="lg:grid-cols-2 items-center grid gap-12">
          <div class="space-y-8">
            <div class="items-start flex gap-6">
              <div class="w-16 h-16 rounded-full bg-neutral-100 items-center justify-center flex flex-shrink-0">
                <svg class="w-8 h-8 text-neutral-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <div class="space-y-2">
                <p class="text-xl font-semibold text-gray-900"><%= safe_phrase('litetracker_onboard-whats_included-1-header', 'Fast Deployment') %></p>
                <p class="text-gray-700/80">
                  <%= safe_phrase('litetracker_onboard-whats_included-1-subheader', 'Launch your product in minutes with our streamlined platform and automated workflows.') %>
                </p>
              </div>
            </div>
            <div class="items-start flex gap-6">
              <div class="w-16 h-16 rounded-full bg-neutral-100 items-center justify-center flex flex-shrink-0">
                <svg class="w-8 h-8 text-neutral-900" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="Windframe_LKTvIYDgY">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                </svg>
              </div>
              <div class="space-y-2">
                <p class="text-xl font-semibold text-gray-900"><%= safe_phrase('litetracker_onboard-whats_included-2-header', 'Premium Security') %></p>
                <p class="text-gray-700/80">
                  <%= safe_phrase('litetracker_onboard-whats_included-2-subheader', 'Enterprise-grade security features to protect your product and customer data.') %>
                </p>
              </div>
            </div>
            <div class="items-start flex gap-6">
              <div class="w-16 h-16 rounded-full bg-neutral-100 items-center justify-center flex flex-shrink-0">
                <svg class="w-8 h-8 text-neutral-900" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="Windframe_W0RsL3m3f">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
              </div>
              <div class="space-y-2">
                <p class="text-xl font-semibold text-gray-900"><%= safe_phrase('litetracker_onboard-whats_included-3-header', 'Analytics Dashboard') %></p>
                <p class="text-gray-700/80">
                  <%= safe_phrase('litetracker_onboard-whats_included-3-subheader', 'Track your launch performance with detailed insights and real-time metrics.') %>
                </p>
              </div>
            </div>
          </div>
          <div class="rounded-2xl bg-white/70 border border-zinc-300/70 inline-block">
            <%= image_tag 'litetracker/hero-image.webp', width: "2880", height: "1606", class: "rounded-xl" %>
          </div>
        </div>
      </div>
    </section>
    <section class="py-16 border-y border-zinc-300/70">
      <div class="mx-auto text-center max-w-4xl space-y-8">
        <div class="space-y-4">
          <p class="text-3xl font-bold text-gray-900"><%= safe_phrase('litetracker_onboard-proof-header', 'Ready to Launch?') %></p>
          <p class="text-lg text-gray-700/80">
            <%= safe_phrase('litetracker_onboard-proof-subheader', 'Join thousands of successful product launches today and claim your $100 credits') %>
          </p>
        </div>
        <div class="sm:flex-row justify-center items-center flex flex-col gap-4">
          <a href="https://app.litetracker.com/" class="inline-flex border border-transparent transition-colors hover:bg-neutral-700 items-center justify-center rounded-lg bg-neutral-900 px-8 py-3 font-semibold text-neutral-100">Get Started Now</a>
          <a href="#" class="inline-flex border border-zinc-300/70 transition-colors hover:bg-black/5 items-center justify-center rounded-lg bg-white/70 px-8 py-3 font-semibold" data-cal-link="neshaz/litetracker" data-cal-namespace="litetracker" data-cal-config='{"layout":"month_view"}'>Talk to Sales</a>
        </div>
        <div class="pt-8 items-center justify-center flex gap-2">
          <div class="flex items-center justify-center max-w-2xl flex -mb-4">
            <div class="flex -space-x-2 overflow-hidden">
              <img class="inline-block size-7 rounded-full ring-2 ring-white" src="https://images.unsplash.com/photo-1491528323818-fdd1faba62cc?ixlib=rb-1.2.1&ixid=eyJhcHBfaWQiOjEyMDd9&auto=format&fit=facearea&facepad=2&w=256&h=256&q=80" alt="">
              <img class="inline-block size-7 rounded-full ring-2 ring-white" src="https://images.unsplash.com/photo-1550525811-e5869dd03032?ixlib=rb-1.2.1&auto=format&fit=facearea&facepad=2&w=256&h=256&q=80" alt="">
              <img class="inline-block size-7 rounded-full ring-2 ring-white" src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?ixlib=rb-1.2.1&ixid=eyJhcHBfaWQiOjEyMDd9&auto=format&fit=facearea&facepad=2.25&w=256&h=256&q=80" alt="">
              <img class="inline-block size-7 rounded-full ring-2 ring-white" src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?ixlib=rb-1.2.1&ixid=eyJhcHBfaWQiOjEyMDd9&auto=format&fit=facearea&facepad=2&w=256&h=256&q=80" alt="">
            </div>
            <div class="flex items-center ml-1">
              <p class="text-sm text-zinc-500"><%= safe_phrase('litetracker_onboard-proof-social-proof', 'Join 3000+ already onboarded') %></p>
            </div>
          </div>
        </div>
      </div>
    </section>
    <%= render "litetrackercom/sections/faq" %>
  </main>
</div>
