<% content_for :title, "#{resolve_title_metadata(request.path) || 'Pivotal Tracker successor | Lite Tracker'}" %>
<% content_for :desciption, 'Pivotal Tracker successor. All the features we all loved are here. Unmatched Simplicity & Ease of Use. Fast Feedback & Momentum.' %>
<% content_for :scripts do %>
  <%= render 'litetrackercom/scripts/yt_script' %>
<% end %>
<main>
  <section id="hero-section" class="relative px-6 lg:px-8 md:h-[calc(100vh-200px)] overflow-hidden">
    <!-- Blur background effect (Astera-style) -->
    <div class="absolute top-[-200px] left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-gradient-to-br from-blue-400/20 via-purple-300/20 to-pink-300/20 rounded-full blur-[100px] opacity-60 will-change-transform pointer-events-none"></div>

    <div class="z-10 mx-auto max-w-7xl flex flex-col items-center gap-10 md:gap-30 py-16 md:pb-0">
      <!-- Badge -->
      <div class="hidden sm:flex sm:justify-center">
        <div class="animate-background rounded-full bg-gradient-to-r from-green-300 via-blue-600 to-red-300 bg-[length:_400%_400%] px-px py-1 [animation-duration:_6s]">
          <a href="https://app.litetracker.com/register" class="relative rounded-full bg-white px-3 py-1.5 text-sm/6 text-gray-600" data-umami-event="signup-click" data-umami-event-location="hero-badge">
            <span class="inline-flex items-center rounded-full bg-green-50 px-2 py-1 text-xs font-medium text-green-700 inset-ring inset-ring-green-600/20">NEW</span>
            <span class="pl-2"><%= safe_phrase('litetracker_hero-badge', 'Automatic import from Jira, Trello, and many more  (08/2025)') %></span>
          </a>
        </div>
      </div>

      <div class="w-full grid grid-cols-1 md:grid-cols-2 justify-center gap-10">
        <div class="">
          <!-- Hero content -->
          <div class="flex flex-col items-center md:items-start gap-6 max-w-4xl text-center md:text-left">
            <h1 class="text-5xl md:leading-15 font-medium tracking-tight text-balance text-gray-900 animate-blur-to-focus">
              <%= safe_phrase('litetracker_hero-header', 'The most complete Pivotal Tracker successor*') %></h1>
            <p class="mx-auto md:mx-0 max-w-2xl text-subheading"><%= safe_phrase('litetracker_hero-subheader', 'Packed with features we all love. Easy 1 minute transfer and complementary onboarding when you book a call.') %></p>
          </div>
          <!-- CTA buttons -->
          <div class="flex items-center justify-center md:justify-start gap-x-6 pt-10 md:pt-24">
            <a href="<%= app_login_url_with_utm('https://app.litetracker.com/register') %>" class="rounded-xl bg-black px-5 py-3 text-base font-semibold text-white shadow-xs hover:bg-black/80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-black/80" data-umami-event="signup-click" data-umami-event-location="hero"><%= safe_phrase('litetracker_btn-get_started', 'Get started') %> &rightarrow;</a>
            <a href="<%= app_login_url_with_utm('https://cal.com/neshaz/litetracker') %>" class="rounded-xl border border-gray-200 px-5 py-3 shadow-xs text-base font-semibold text-gray-900 hover:bg-gray-100" data-umami-event="cta-demo" data-umami-event-location="hero"><%= safe_phrase('litetracker_btn-human_talk', 'Talk to human') %> <span aria-hidden="true">→</span></a>
          </div>

          <!-- Social proof -->
          <div class="flex flex-col sm:flex-row items-center justify-center md:justify-start gap-4 pt-8">
            <div class="flex -space-x-2">
              <img src="https://i.pravatar.cc/32?img=<%= rand(1..70) %>" alt="" class="w-8 h-8 rounded-full border-2 border-white object-cover">
              <img src="https://i.pravatar.cc/32?img=<%= rand(1..70) %>" alt="" class="w-8 h-8 rounded-full border-2 border-white object-cover">
              <img src="https://i.pravatar.cc/32?img=<%= rand(1..70) %>" alt="" class="w-8 h-8 rounded-full border-2 border-white object-cover">
              <img src="https://i.pravatar.cc/32?img=<%= rand(1..70) %>" alt="" class="w-8 h-8 rounded-full border-2 border-white object-cover">
              <img src="https://i.pravatar.cc/32?img=<%= rand(1..70) %>" alt="" class="w-8 h-8 rounded-full border-2 border-white object-cover">
            </div>
            <div class="flex flex-col sm:flex-row items-center gap-1 sm:gap-2">
              <div class="flex items-center">
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              </div>
              <span class="text-sm text-gray-600">Loved by Pivotal Tracker teams</span>
            </div>
          </div>
        </div>

        <!-- Video section -->
        <div id="hero-video-wrapper" class="w-full h-full md:absolute md:left-1/2 md:w-1/2 md:h-min rounded-2xl bg-white p-2 border border-gray-200 shadow-2xl">
          <div class="group relative w-full rounded-xl overflow-hidden aspect-[2880/1606] cursor-pointer">
            <%= image_tag 'litetracker/default.png', class: "w-full h-full object-cover object-[left_center] opacity-100 transition-opacity duration-1000 group-hover:opacity-0", alt: 'LiteTracker app' %>
            <iframe
              id="hero-video"
              class="absolute inset-0 w-full h-full object-cover object-[left_center] opacity-0 transition-opacity duration-1000 group-hover:opacity-100"
              src="https://www.youtube.com/embed/-1SGdQVKJkY?si=zf_p2taEJrLZYmqu?autoplay=0&mute=1&loop=1&controls=1&disablekb=1&fs=0&modestbranding=1&rel=0&iv_load_policy=3&enablejsapi=1&playsinline=1&showinfo=0"
              title="LiteTracker Video"
              frameborder="0"
              allow="autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen>
            </iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="features-section" class="relative px-6 lg:px-8">
    <div class="relative mx-auto max-w-7xl py-8 sm:pt-12 flex items-center flex-col justify-start gap-y-24 w-full">
      <div class="mx-auto max-w-3xl flex flex-col gap-y-6 justify-center w-full text-center">
        <div class="flex items-center justify-center text-blue-dark text-xs">
          <svg class="h-4 w-4"  fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
          <p class="pl-1 font-bold">Pivotal Tracker Features</p>
        </div>
        <h3 class="text-heading">
          <%= safe_phrase('litetracker_seamless-header', 'All the Features We Loved in Pivotal Tracker') %>
        </h3>
        <p class="text-subheading"><%= safe_phrase('litetracker_seamless-subheader', 'Pivotal Tracker set the standard for agile project management with its elegant simplicity and powerful workflow. From automatic velocity calculation to the iconic story states, it helped thousands of teams ship better software. LiteTracker preserves everything that made Pivotal Tracker special—story points, iteration planning, epics, and the accept/reject workflow—while adding modern improvements teams have been asking for.') %></p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 justify-center gap-10">
        <!-- Velocity Tracking -->
        <div class="w-full">
          <div class="flex flex-col gap-y-8">
            <div class="rounded-xl shadow-xl bg-white h-100 overflow-hidden">
              <%= image_tag 'litetracker/example-analytics.png', class: "rounded-xl w-full h-full object-left object-cover", alt: 'Velocity Tracking' %>
            </div>
            <div class="flex flex-col gap-4 w-full text-sm">
              <div class="flex flex-col gap-2">
                <p class="text-[#020a0f] font-medium">Velocity Tracking</p>
                <p class="text-[#47474f] font-normal">Automatic velocity calculation based on completed story points. Track your team's rolling average over iterations.</p>
              </div>
              <a href="/features" class="flex items-center text-black font-semibold" data-umami-event="learn-more" data-umami-event-section="features">
                <span>Learn more</span>
                <svg class="h-4"  width="24" height="24" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z"/>
                  <polyline points="9 6 15 12 9 18" />
                </svg>
              </a>
            </div>
          </div>
        </div>
        <!-- Story Points -->
        <div class="w-full">
          <div class="flex flex-col gap-y-8">
            <div class="rounded-xl shadow-xl bg-white h-100 overflow-hidden">
              <%= image_tag 'litetracker/carousel-estimate.svg', class: "rounded-xl w-full h-full object-left object-cover", alt: 'Story Points' %>
            </div>
            <div class="flex flex-col gap-4 w-full text-sm">
              <div class="flex flex-col gap-2">
                <p class="text-[#020a0f] font-medium">Story Points</p>
                <p class="text-[#47474f] font-normal">Estimate effort using the Fibonacci scale (0, 1, 2, 3, 5, 8). Quick point assignment directly from story cards.</p>
              </div>
              <a href="/features" class="flex items-center text-black font-semibold" data-umami-event="learn-more" data-umami-event-section="features">
                <span>Learn more</span>
                <svg class="h-4"  width="24" height="24" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z"/>
                  <polyline points="9 6 15 12 9 18" />
                </svg>
              </a>
            </div>
          </div>
        </div>
        <!-- Iteration Planning -->
        <div class="w-full">
          <div class="flex flex-col gap-y-8">
            <div class="rounded-xl shadow-xl bg-white h-100 overflow-hidden">
              <%= image_tag 'litetracker/iteration-planning.webp', class: "rounded-xl w-full h-full object-left object-cover", alt: 'Iteration Planning' %>
            </div>
            <div class="flex flex-col gap-4 w-full text-sm">
              <div class="flex flex-col gap-2">
                <p class="text-[#020a0f] font-medium">Iteration Planning</p>
                <p class="text-[#47474f] font-normal">Organize work into time-boxed iterations. Automatic sprint backlog management based on velocity.</p>
              </div>
              <a href="/features" class="flex items-center text-black font-semibold" data-umami-event="learn-more" data-umami-event-section="features">
                <span>Learn more</span>
                <svg class="h-4"  width="24" height="24" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z"/>
                  <polyline points="9 6 15 12 9 18" />
                </svg>
              </a>
            </div>
          </div>
        </div>
        <!-- Accept/Reject Workflow -->
        <div class="w-full">
          <div class="flex flex-col gap-y-8">
            <div class="rounded-xl shadow-xl bg-white h-100 overflow-hidden">
              <%= image_tag 'litetracker/carousel-start.svg', class: "rounded-xl w-full h-full object-left object-cover", alt: 'Accept/Reject Workflow' %>
            </div>
            <div class="flex flex-col gap-4 w-full text-sm">
              <div class="flex flex-col gap-2">
                <p class="text-[#020a0f] font-medium">Accept/Reject Workflow</p>
                <p class="text-[#47474f] font-normal">Story states flow from Started to Finished to Delivered. Stakeholders can Accept or Reject completed work.</p>
              </div>
              <a href="/features" class="flex items-center text-black font-semibold" data-umami-event="learn-more" data-umami-event-section="features">
                <span>Learn more</span>
                <svg class="h-4"  width="24" height="24" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z"/>
                  <polyline points="9 6 15 12 9 18" />
                </svg>
              </a>
            </div>
          </div>
        </div>
        <!-- Epics -->
        <div class="w-full">
          <div class="flex flex-col gap-y-8">
            <div class="rounded-xl shadow-xl bg-white h-100 overflow-hidden">
              <%= image_tag 'litetracker/features-epics.webp', class: "rounded-xl w-full h-full object-left object-cover", alt: 'Epics' %>
            </div>
            <div class="flex flex-col gap-4 w-full text-sm">
              <div class="flex flex-col gap-2">
                <p class="text-[#020a0f] font-medium">Epics</p>
                <p class="text-[#47474f] font-normal">Group related stories into epics for larger initiatives. Track progress across multiple stories at a glance.</p>
              </div>
              <a href="/features" class="flex items-center text-black font-semibold" data-umami-event="learn-more" data-umami-event-section="features">
                <span>Learn more</span>
                <svg class="h-4"  width="24" height="24" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z"/>
                  <polyline points="9 6 15 12 9 18" />
                </svg>
              </a>
            </div>
          </div>
        </div>
        <!-- Labels & Filtering -->
        <div class="w-full">
          <div class="flex flex-col gap-y-8">
            <div class="rounded-xl shadow-xl bg-white h-100 overflow-hidden">
              <%= image_tag 'litetracker/feature-labels.svg', class: "rounded-xl w-full h-full object-left object-cover", alt: 'Labels and Filtering' %>
            </div>
            <div class="flex flex-col gap-4 w-full text-sm">
              <div class="flex flex-col gap-2">
                <p class="text-[#020a0f] font-medium">Labels & Filtering</p>
                <p class="text-[#47474f] font-normal">Organize stories with custom labels. Powerful search and filtering to find exactly what you need.</p>
              </div>
              <a href="/features" class="flex items-center text-black font-semibold" data-umami-event="learn-more" data-umami-event-section="features">
                <span>Learn more</span>
                <svg class="h-4"  width="24" height="24" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z"/>
                  <polyline points="9 6 15 12 9 18" />
                </svg>
              </a>
            </div>
          </div>
        </div>
        <!-- Activity Feed -->
        <div class="w-full">
          <div class="flex flex-col gap-y-8">
            <div class="rounded-xl shadow-xl bg-white h-100 overflow-hidden">
              <%= image_tag 'litetracker/feature-history.svg', class: "rounded-xl w-full h-full object-left object-cover", alt: 'Activity Feed' %>
            </div>
            <div class="flex flex-col gap-4 w-full text-sm">
              <div class="flex flex-col gap-2">
                <p class="text-[#020a0f] font-medium">Activity Feed</p>
                <p class="text-[#47474f] font-normal">Real-time activity stream showing all project changes. Stay informed about what your team is working on.</p>
              </div>
              <a href="/features" class="flex items-center text-black font-semibold" data-umami-event="learn-more" data-umami-event-section="features">
                <span>Learn more</span>
                <svg class="h-4"  width="24" height="24" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z"/>
                  <polyline points="9 6 15 12 9 18" />
                </svg>
              </a>
            </div>
          </div>
        </div>
        <!-- Blockers -->
        <div class="w-full">
          <div class="flex flex-col gap-y-8">
            <div class="rounded-xl shadow-xl bg-white h-100 overflow-hidden">
              <%= image_tag 'litetracker/feature-blockers.svg', class: "rounded-xl w-full h-full object-left object-cover", alt: 'Blockers' %>
            </div>
            <div class="flex flex-col gap-4 w-full text-sm">
              <div class="flex flex-col gap-2">
                <p class="text-[#020a0f] font-medium">Blockers</p>
                <p class="text-[#47474f] font-normal">Flag stories that are blocked and track dependencies. Quickly identify and resolve impediments.</p>
              </div>
              <a href="/features" class="flex items-center text-black font-semibold" data-umami-event="learn-more" data-umami-event-section="features">
                <span>Learn more</span>
                <svg class="h-4"  width="24" height="24" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z"/>
                  <polyline points="9 6 15 12 9 18" />
                </svg>
              </a>
            </div>
          </div>
        </div>
        <!-- Project Analytics -->
        <div class="w-full">
          <div class="flex flex-col gap-y-8">
            <div class="rounded-xl shadow-xl bg-white h-100 overflow-hidden">
              <%= image_tag 'litetracker/example-analytics.png', class: "rounded-xl w-full h-full object-left object-cover", alt: 'Project Analytics' %>
            </div>
            <div class="flex flex-col gap-4 w-full text-sm">
              <div class="flex flex-col gap-2">
                <p class="text-[#020a0f] font-medium">Project Analytics</p>
                <p class="text-[#47474f] font-normal">Burndown charts, velocity trends, and cycle time metrics. Data-driven insights to improve your process.</p>
              </div>
              <a href="/features" class="flex items-center text-black font-semibold" data-umami-event="learn-more" data-umami-event-section="features">
                <span>Learn more</span>
                <svg class="h-4"  width="24" height="24" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z"/>
                  <polyline points="9 6 15 12 9 18" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="features-epics-section" class="relative px-6 pt-14 lg:px-8">
    <div class="relative mx-auto max-w-7xl py-16 sm:pt-24">
      <div class="mx-auto max-w-7xl md:px-6 lg:px-8">
        <div class="grid grid-cols-1 gap-x-36 gap-y-16 sm:gap-y-20 lg:grid-cols-2 lg:content-start">
          <div class="flex flex-col gap-10 px-6 lg:px-0">
            <div class="flex flex-col gap-4">
              <p class="flex items-center gap-1 text-orange font-semibold text-sm">
                <svg class="h-4 w-4"  width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z"/>
                  <rect x="4" y="5" width="16" height="16" rx="2" />
                  <line x1="16" y1="3" x2="16" y2="7" />
                  <line x1="8" y1="3" x2="8" y2="7" />
                  <line x1="4" y1="11" x2="20" y2="11" />
                  <rect x="8" y="15" width="2" height="2" />
                </svg>
                Epics
              </p>
              <p class="text-heading tracking-tight text-black"><%= safe_phrase('litetracker_epics-header', 'Group Stories Into Larger Initiatives') %></p>
              <p class="text-subheading">Epics let you organize related stories under a single theme or feature. Track progress across multiple stories and see completion at a glance.</p>
              <ul class="space-y-3 text-subheading">
                <li class="flex items-start">
                  <span class="text-orange mr-2">•</span>
                  Visual progress tracking
                </li>
                <li class="flex items-start">
                  <span class="text-orange mr-2">•</span>
                  Filter backlog by epic
                </li>
                <li class="flex items-start">
                  <span class="text-orange mr-2">•</span>
                  Epic states: drafting, in progress, done
                </li>
              </ul>
            </div>
            <div class="h-11 w-fit">
