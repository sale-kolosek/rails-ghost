                  <polyline points="9 6 15 12 9 18" />
                </svg>
              </a>
            </div>
          </div>
        </div>
        <div class="grow flex items-center justify-start sm:px-6 lg:px-0 max-w-md w-full xs:w-px">
          <div class="grow h-80 xs:h-112 aspect-square relative px-2 xs:px-6 mx-auto rounded-2xl sm:pl-0 sm:pr-0 lg:mx-0">
            <div class="xs:absolute shadow-xl rounded-2xl overflow-hidden">
              <%= image_tag 'litetracker/default.png', alt: "LiteTracker Dashboard", class: "w-full h-full rounded-2xl object-cover object-center" %>
