  <!-- 3. Structure Beats Flexibility Section -->
  <section class="bg-[#F6F6F8] relative px-6 lg:px-8 py-16 sm:py-24">
    <div class="mx-auto max-w-4xl">
      <div class="mx-auto max-w-xl flex flex-col gap-y-6 justify-center w-full text-center mb-16">
        <h2 class="text-heading sm:text-5xl tracking-wide">
          Structure Beats Flexibility
        </h2>
        <p class="text-base font-normal text-gray-500 sm:text-lg/8">
          Open-ended tools feel powerful. But without guardrails, teams drift. Here's what that looks like over 6 months.
        </p>
      </div>

      <!-- Graph: Blank Canvas vs Guardrails -->
      <div class="bg-white rounded-3xl p-8 border border-[#E6E6EB] mb-10">
        <div class="flex items-center justify-between mb-6">
          <p class="text-sm font-semibold text-gray-900">Sprint output over time</p>
          <div class="flex items-center gap-6">
            <div class="flex items-center gap-2">
              <span class="w-5 h-px border-t-2 border-dashed border-gray-400"></span>
              <span class="text-xs text-gray-500">Blank canvas</span>
