        <div class="bg-white rounded-3xl p-8 border border-[#E6E6EB]">
          <div class="flex items-center justify-between mb-6">
            <p class="text-sm font-semibold text-gray-900">Technical debt</p>
            <p class="text-sm text-gray-500">cost/sprint</p>
          </div>
          <div class="relative">
            <svg viewBox="0 0 280 200" class="w-full h-auto" fill="none" xmlns="http://www.w3.org/2000/svg">
              <line x1="0" y1="40" x2="280" y2="40" stroke="#E6E6EB" stroke-width="1"/>
