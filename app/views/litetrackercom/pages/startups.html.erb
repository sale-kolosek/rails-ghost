            </defs>
            <path d="M40 148 C80 140, 110 128, 150 112 C190 96, 220 80, 260 66 C300 54, 330 44, 370 36 C410 30, 440 28, 450 27 L450 170 L40 170 Z" fill="url(#guardrailsGrad)"/>
            <path d="M40 148 C70 142, 90 136, 120 130 C150 124, 170 122, 200 124 C230 126, 250 130, 280 136 C310 142, 330 146, 360 150 C390 154, 420 156, 450 158" stroke="#9CA3AF" stroke-width="2" stroke-linecap="round" stroke-dasharray="6 4"/>
            <path d="M40 148 C80 140, 110 128, 150 112 C190 96, 220 80, 260 66 C300 54, 330 44, 370 36 C410 30, 440 28, 450 27" stroke="#020a0f" stroke-width="2" stroke-linecap="round"/>
            <circle cx="40" cy="148" r="3" fill="#020a0f"/>
            <circle cx="150" cy="112" r="3" fill="#020a0f"/>
            <circle cx="260" cy="66" r="3" fill="#020a0f"/>
            <circle cx="370" cy="36" r="3" fill="#020a0f"/>
            <circle cx="450" cy="27" r="3" fill="#020a0f"/>
            <circle cx="40" cy="148" r="3" fill="#9CA3AF"/>
            <circle cx="150" cy="124" r="3" fill="#9CA3AF"/>
            <circle cx="260" cy="136" r="3" fill="#9CA3AF"/>
            <circle cx="370" cy="150" r="3" fill="#9CA3AF"/>
            <circle cx="450" cy="158" r="3" fill="#9CA3AF"/>
            <text x="40" y="188" fill="#9CA3AF" font-size="9" font-family="Inter, sans-serif" text-anchor="middle">Mo 1</text>
            <text x="150" y="188" fill="#9CA3AF" font-size="9" font-family="Inter, sans-serif" text-anchor="middle">Mo 2</text>
            <text x="260" y="188" fill="#9CA3AF" font-size="9" font-family="Inter, sans-serif" text-anchor="middle">Mo 3</text>
            <text x="370" y="188" fill="#9CA3AF" font-size="9" font-family="Inter, sans-serif" text-anchor="middle">Mo 5</text>
            <text x="450" y="188" fill="#9CA3AF" font-size="9" font-family="Inter, sans-serif" text-anchor="middle">Mo 6</text>
          </svg>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white rounded-3xl p-8 border border-[#E6E6EB]">
          <p class="text-sm font-semibold text-gray-900 mb-6">Blank canvas tools</p>
          <ul class="space-y-3 text-sm/6 text-gray-600">
            <li class="flex gap-x-3">
              <svg class="h-6 w-5 flex-none text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
              </svg>
              Empty boards, no direction
            </li>
            <li class="flex gap-x-3">
              <svg class="h-6 w-5 flex-none text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
              </svg>
              Endless customization overhead
            </li>
