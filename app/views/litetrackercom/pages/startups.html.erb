              <circle cx="30" cy="168" r="3" fill="#9CA3AF"/>
              <circle cx="75" cy="160" r="3" fill="#9CA3AF"/>
              <circle cx="115" cy="146" r="3" fill="#9CA3AF"/>
              <circle cx="155" cy="118" r="3" fill="#9CA3AF"/>
              <circle cx="195" cy="82" r="3" fill="#9CA3AF"/>
              <circle cx="235" cy="46" r="3" fill="#9CA3AF"/>
              <circle cx="265" cy="24" r="3" fill="#9CA3AF"/>
              <text x="30" y="196" fill="#9CA3AF" font-size="9" font-family="Inter, sans-serif" text-anchor="middle">Mo 1</text>
              <text x="115" y="196" fill="#9CA3AF" font-size="9" font-family="Inter, sans-serif" text-anchor="middle">Mo 3</text>
              <text x="195" y="196" fill="#9CA3AF" font-size="9" font-family="Inter, sans-serif" text-anchor="middle">Mo 6</text>
              <text x="265" y="196" fill="#9CA3AF" font-size="9" font-family="Inter, sans-serif" text-anchor="middle">Mo 9</text>
            </svg>
          </div>
          <div class="mt-4 pt-4 border-t border-[#E6E6EB]">
            <p class="text-xs text-gray-500">Without structure, debt compounds exponentially. Rework costs more than building right.</p>
          </div>
        </div>
      </div>

      <p class="mt-12 text-center text-lg font-semibold text-gray-900">
        Unstructured execution is the biggest hidden cost in early-stage startups.
      </p>
