<% content_for(:title) { "LiteTracker for Startups | Turn Effort Into Measurable ROI" } %>
<% content_for(:description) { "Guided, story-driven execution designed to maximize product ROI. Every sprint, every feature, every line of code moves your startup forward." } %>

<main>
  <!-- 1. Hero Section -->
  <section id="hero-section" class="bg-[#F6F6F8] relative px-6 lg:px-8 overflow-hidden">
    <div class="z-10 relative mx-auto max-w-3xl flex flex-col items-center gap-6 py-20 md:py-28">
      <div class="flex flex-col items-center gap-4 text-center">
        <h1 class="text-4xl md:text-5xl md:leading-14 font-semibold tracking-tight text-gray-900 animate-blur-to-focus">
          Get 3x of ROI.<br>
          Proven by 100s of Startups.
        </h1>
        <p class="max-w-xl text-base font-normal text-gray-500 sm:text-lg/8">
          Story-driven sprints that turn every feature and line of code into measurable startup growth.
        </p>
      </div>
      <!-- CTA buttons -->
      <div class="flex flex-col items-center gap-4 pt-2">
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="<%= app_login_url_with_utm('https://app.litetracker.com/register') %>" class="bg-black w-fit flex items-center rounded-xl px-5 py-2.5 text-sm/6 font-semibold text-white border border-[#E6E6EB]" data-umami-event="signup-click" data-umami-event-location="startups-hero">
            Start for Free
            <svg class="h-4" width="24" height="24" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z"/>
              <polyline points="9 6 15 12 9 18" />
            </svg>
          </a>
          <a href="#" class="w-fit flex items-center rounded-xl px-5 py-2.5 text-sm/6 font-semibold text-black border border-[#E6E6EB] hover:bg-[#FAFAFA]" data-cal-link="neshaz/litetracker" data-cal-namespace="litetracker" data-cal-config='{"layout":"month_view"}' data-umami-event="cta-demo" data-umami-event-location="startups-hero">
            Talk to Human
            <svg class="h-4" width="24" height="24" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z"/>
              <polyline points="9 6 15 12 9 18" />
            </svg>
          </a>
        </div>
        <a href="/pricing" class="text-sm text-gray-500 hover:text-gray-900" data-umami-event="pricing-click" data-umami-event-location="startups-hero">See pricing &rarr;</a>
      </div>

      <!-- Social proof -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
        <div class="flex -space-x-2">
          <img src="https://i.pravatar.cc/32?img=<%= rand(1..70) %>" alt="" class="w-8 h-8 rounded-full border-2 border-white object-cover">
          <img src="https://i.pravatar.cc/32?img=<%= rand(1..70) %>" alt="" class="w-8 h-8 rounded-full border-2 border-white object-cover">
          <img src="https://i.pravatar.cc/32?img=<%= rand(1..70) %>" alt="" class="w-8 h-8 rounded-full border-2 border-white object-cover">
          <img src="https://i.pravatar.cc/32?img=<%= rand(1..70) %>" alt="" class="w-8 h-8 rounded-full border-2 border-white object-cover">
          <img src="https://i.pravatar.cc/32?img=<%= rand(1..70) %>" alt="" class="w-8 h-8 rounded-full border-2 border-white object-cover">
        </div>
        <div class="flex flex-col sm:flex-row items-center gap-1 sm:gap-2">
          <div class="flex items-center">
            <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          </div>
          <span class="text-sm text-gray-600">Rated 5/5 by startup teams</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Execution Problem Section -->
  <section class="relative px-6 lg:px-8 py-16 sm:py-24">
    <div class="mx-auto max-w-4xl">
      <div class="mx-auto max-w-xl flex flex-col gap-y-6 justify-center w-full text-center">
        <h2 class="text-heading sm:text-5xl tracking-wide">
          It's an Execution Problem.
        </h2>
