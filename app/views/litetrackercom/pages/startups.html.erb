            <text x="0" y="34" fill="#9CA3AF" font-size="9" font-family="Inter, sans-serif">High</text>
            <text x="0" y="114" fill="#9CA3AF" font-size="9" font-family="Inter, sans-serif">Med</text>
            <text x="0" y="154" fill="#9CA3AF" font-size="9" font-family="Inter, sans-serif">Low</text>
            <defs>
              <linearGradient id="guardrailsGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#020a0f" stop-opacity="0.06"/>
                <stop offset="100%" stop-color="#020a0f" stop-opacity="0"/>
