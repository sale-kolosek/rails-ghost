<!-- ========== HEADER ========== -->
<header class="lr-header">
  <div class="lr-header-inner">
    <a href="/" class="lr-logo">
      <svg viewBox="0 0 28 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:24px;height:20px;"><path d="M22.6563 0H4.6115L0 7.13257L13.6339 24L27.2679 7.13257L22.6563 0ZM13.6339 19.9028L3.17686 6.96541L6.01941 2.56621H21.2465L24.091 6.96541H7.88961L17.9149 9.45754C18.2862 9.55131 18.628 9.73611 18.909 9.99506C19.1899 10.254 19.4011 10.5788 19.5233 10.9399C19.6455 11.3009 19.6747 11.6866 19.6083 12.0618C19.5419 12.4369 19.382 12.7896 19.1433 13.0875L13.6339 19.9028Z" fill="url(#kolosekGradFeatured)"/><defs><linearGradient id="kolosekGradFeatured" x1="27.2679" y1="0" x2="12.3052" y2="26.7966" gradientUnits="userSpaceOnUse"><stop stop-color="#2193F4"/><stop offset="1" stop-color="#22C9F5"/></linearGradient></defs></svg>
      Kolosek
    </a>
    <nav class="lr-nav">
      <a href="/about">About us</a>
      <a href="/featured">Featured projects</a>
      <a href="https://poslovi.kolosek.com" target="_blank">Careers</a>
      <a href="/contact">Contact</a>
      <a href="/contact" class="lr-btn lr-btn-primary lr-mobile-nav-cta">Start a project</a>
    </nav>
    <div class="lr-header-right">
      <a href="https://poslovi.kolosek.com" target="_blank" class="lr-badge-hiring">We are hiring</a>
      <a href="/contact" class="lr-btn lr-btn-primary">
        Start a project
        <svg viewBox="0 0 16 16" fill="none"><path d="M3.33 8h9.34M8.67 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <button class="lr-menu-btn">
        <svg viewBox="0 0 24 24" fill="none"><path d="M3 12h18M3 6h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>
</header>

<!-- ========== HERO ========== -->
<section class="lr-hero lr-hero-about lr-fade-in">
  <div class="lr-hero-bg-nodes">
    <span></span><span></span><span></span><span></span><span></span>
    <span></span><span></span><span></span><span></span><span></span>
    <span></span><span></span><span></span><span></span>
  </div>
  <div class="container">
    <div class="lr-hero-tag">
      <svg viewBox="0 0 24 24" fill="none"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M3.27 6.96L12 12.01l8.73-5.05M12 22.08V12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Our work
    </div>
    <h1>Featured <span>Projects</span></h1>
    <p>AI-powered products and platforms we've shipped for startups, enterprises, and ourselves.</p>
  </div>
</section>

<!-- ========== OUR PRODUCTS ========== -->
<section class="lr-section lr-section-bordered lr-fade-in">
  <div class="container">
    <div class="lr-section-header lr-section-header-center">
      <div class="lr-section-tag">
        <svg viewBox="0 0 24 24" fill="none" style="width:14px;height:14px;"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Our products
      </div>
      <h2 class="lr-section-heading">Products we built<br><span>and own</span></h2>
      <p class="lr-section-desc">Platforms we created from the ground up, powered by AI-assisted development and continuous innovation.</p>
    </div>

    <!-- LiteTracker -->
    <div class="lr-showcase-card lr-fade-in">
      <div class="lr-showcase-img">
        <%= image_tag 'litetracker/hero-image.webp', alt: 'LiteTracker' %>
      </div>
      <div class="lr-showcase-text">
        <h3>LiteTracker</h3>
        <p class="lr-showcase-subtitle">The most complete Pivotal Tracker successor</p>
        <p>Agile project management platform built for teams migrating from Pivotal Tracker. Story management, velocity tracking, and real-time collaboration with integrations for GitHub, Slack, and 50+ tools. Built end-to-end with AI-assisted development workflows.</p>
        <a href="https://litetracker.com" class="lr-btn lr-btn-secondary" target="_blank">
          Visit site
          <svg viewBox="0 0 16 16" fill="none"><path d="M4 12l8-8M6 4h6v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>

    <!-- Ruby.ci -->
    <div class="lr-showcase-card lr-showcase-card-reverse lr-fade-in">
      <div class="lr-showcase-img">
        <%= image_tag 'kolosek/featured-ruby-ci.jpg', alt: 'Ruby.ci' %>
      </div>
      <div class="lr-showcase-text">
        <h3>Ruby.ci</h3>
        <p class="lr-showcase-subtitle">Best CI platform for your Rails application</p>
        <p>A 2-minute setup CI platform with no extra code, purpose-built for Ruby on Rails applications. Combining Elixir, Ruby, and React into a seamless developer experience with intelligent test analysis and AI-powered failure diagnostics.</p>
        <a href="https://ruby.ci" class="lr-btn lr-btn-secondary" target="_blank">
          Visit site
          <svg viewBox="0 0 16 16" fill="none"><path d="M4 12l8-8M6 4h6v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ========== CLIENT PROJECTS ========== -->
<section class="lr-section lr-section-bordered lr-fade-in">
  <div class="container">
    <div class="lr-section-header lr-section-header-center">
      <div class="lr-section-tag">
        <svg viewBox="0 0 24 24" fill="none" style="width:14px;height:14px;"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Client projects
      </div>
      <h2 class="lr-section-heading">Platforms we built<br><span>for our clients</span></h2>
      <p class="lr-section-desc">From Series B startups to enterprise platforms, we've partnered with ambitious teams to ship products that scale.</p>
    </div>
    <div class="lr-bento lr-stagger">
      <div class="lr-bento-card lr-stagger-item">
        <div class="lr-bento-card-img">
          <%= image_tag 'kolosek/featured-movie-pilot.png', alt: 'MoviePilot' %>
        </div>
        <div class="lr-bento-card-text">
          <h3>MoviePilot</h3>
          <p>Germany's leading alternative to IMDB, serving millions of visitors. We are the sole technology partner, building and maintaining the entire platform with Ruby on Rails and React.</p>
        </div>
      </div>
      <div class="lr-bento-card lr-stagger-item">
        <div class="lr-bento-card-img">
          <%= image_tag 'kolosek/featured-squire.avif', alt: 'Squire' %>
        </div>
        <div class="lr-bento-card-text">
          <h3>Squire</h3>
          <p>All-in-one business management platform for barbershops, trusted by 32,000+ barbers. We engineered the booking engine, payment processing, and staff management features.</p>
        </div>
      </div>
      <div class="lr-bento-card lr-stagger-item">
        <div class="lr-bento-card-img">
          <%= image_tag 'kolosek/featured-boardspan.png', alt: 'Boardspan' %>
        </div>
        <div class="lr-bento-card-text">
          <h3>Boardspan</h3>
          <p>Technology-enabled solutions for boards of directors. We built board assessments, director evaluations, and governance tools with intelligent matching and analytics.</p>
        </div>
      </div>
      <div class="lr-bento-card lr-stagger-item">
        <div class="lr-bento-card-img">
          <%= image_tag 'kolosek/featured-wrap.png', alt: 'WRAP' %>
        </div>
        <div class="lr-bento-card-text">
          <h3>WRAP</h3>
          <p>Mobile engagement platform backed by Series B funding. We partnered with a 100-person SF team to build story-driven messaging experiences with no-code publishing tools.</p>
        </div>
      </div>
      <div class="lr-bento-card lr-stagger-item">
        <div class="lr-bento-card-img">
          <%= image_tag 'kolosek/featured-oschool.jpg', alt: 'O.school' %>
        </div>
        <div class="lr-bento-card-text">
          <h3>O.school</h3>
          <p>Science-based educational platform featured on TechCrunch. We built the live streaming virtual classroom, moderated chat, and content delivery infrastructure from scratch.</p>
        </div>
      </div>
      <div class="lr-bento-card lr-stagger-item">
        <div class="lr-bento-card-img">
          <%= image_tag 'kolosek/featured-simone-leblanc.jpg', alt: 'Simone LeBlanc' %>
        </div>
        <div class="lr-bento-card-text">
          <h3>Simone LeBlanc</h3>
          <p>LA-based gifting company with curated gift boxes for individuals and businesses. We built the e-commerce platform with custom gift solutions, volume gifting, and corporate concierge.</p>
        </div>
      </div>
      <div class="lr-bento-card lr-stagger-item">
        <div class="lr-bento-card-img">
          <%= image_tag 'kolosek/featured-next-closet.jpg', alt: 'The Next Closet' %>
        </div>
        <div class="lr-bento-card-text">
          <h3>The Next Closet</h3>
          <p>The largest marketplace for second-hand designer brands in the Netherlands. We built and maintain the web and mobile apps serving millions of visitors per month.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ========== MORE PROJECTS ========== -->
<section class="lr-section lr-section-bordered lr-fade-in">
  <div class="container">
    <div class="lr-section-header lr-section-header-center">
      <div class="lr-section-tag">
        <svg viewBox="0 0 24 24" fill="none" style="width:14px;height:14px;"><path d="M16 18l6-6-6-6M8 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        More projects
      </div>
      <h2 class="lr-section-heading">Developer tools<br><span>we created</span></h2>
      <p class="lr-section-desc">Internal tools and open-source projects born from our engineering practice.</p>
    </div>
    <div class="lr-metrics-grid lr-stagger">
      <div class="lr-metric-card lr-stagger-item">
        <div class="lr-more-project-img">
          <%= image_tag 'kolosek/featured-sniffler.jpg', alt: 'Sniffler' %>
        </div>
        <h3>
          <svg viewBox="0 0 24 24" fill="none"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/></svg>
          Sniffler
        </h3>
        <p>AI-powered code reviewer that integrates with your GitHub workflow. When a pull request is opened or updated, Sniffler scans, reports errors, and suggests fixes automatically.</p>
      </div>
      <div class="lr-metric-card lr-stagger-item">
        <div class="lr-more-project-img">
          <%= image_tag 'kolosek/featured-git-puller.jpg', alt: 'GitPuller' %>
        </div>
        <h3>
          <svg viewBox="0 0 24 24" fill="none"><path d="M6 3v12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="18" cy="6" r="3" stroke="currentColor" stroke-width="2"/><circle cx="6" cy="18" r="3" stroke="currentColor" stroke-width="2"/><path d="M18 9a9 9 0 01-9 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          GitPuller
        </h3>
        <p>Pull request manager that gives complete transparency into your development process without requiring access to your source code. Track progress and ship with confidence.</p>
      </div>
    </div>
  </div>
</section>

<!-- ========== CTA ========== -->
<section class="lr-cta lr-fade-in">
  <div class="container">
    <h2>Ready to build something<br><span>intelligent together?</span></h2>
    <a href="/contact" class="lr-btn lr-btn-primary lr-btn-lg">
      Start a project
