<!DOCTYPE html>
<html lang="<%= @settings['lang'] %>">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= @settings['meta_description'].present? ? @settings['meta_description'] : 'Reduce Ruby Dev Costs by 80% with 256x faster automated tests and improved performance workflow' %>">
    <meta name="keywords" content="ruby, continuous integration, automated tests">
    <title>
      <%= content_for?(:title) ? yield(:title) : "Ruby.ci fastest Ruby on Rails CI in cloud" %>
    </title>

    <%= favicon_link_tag 'logo-linear.svg' %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="canonical" href="<%= request.url %>" />

    <%= javascript_include_tag "application" %>
    <% if current_user.present? && current_user.admin? %>
      <%= javascript_include_tag "phrasing" %>
      <%= stylesheet_link_tag "application" %>
    <% end %>

    <script src="https://cdn.tailwindcss.com"></script>

    <style>
      html, body {
        font-family: "Inter", sans-serif;
        font-optical-sizing: auto;
      }
      #footer-imgs {
        zoom: 50%;
        @media only screen and (min-width: 1024px) {
          zoom: 100%;
        }
      }
    </style>
    <script>
      window.dataLayer = window.dataLayer || [];
    </script>
    <%= raw @settings['codeinjection_head'] %>
    <%= render 'rubyci/layouts/partials/scripts_header' %>
    <%= render 'rubyci/layouts/partials/pricing_script' if action_name == 'pricing' %>
    <%= raw @header_script if @header_script.present? %>
  </head>

  <body class="bg-gray-900 relative">
    <%= render 'rubyci/layouts/partials/scripts_body' %>
    <div style="background-color: white;">
      <%= render 'phrasing/initializer' %>
    </div>
    <%#= render 'layouts/partials/top' %>
    <%= render 'rubyci/layouts/partials/header' %>
    <div class="page-wrapper">
      <%= render "shared/flash" %>
      <%= yield %>
      <%= render 'rubyci/layouts/partials/footer' %>
    </div>
    <%= render 'rubyci/layouts/partials/features_script' if action_name == 'features' %>
    <%= raw @settings['codeinjection_foot'] %>
    <%= raw @footer_script if @footer_script.present? %>
  </body>
</html>
