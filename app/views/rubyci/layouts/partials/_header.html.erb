<header class="relative isolate z-40 sticky top-0 bg-gray-950 border-0 border-b border-zinc-900">
  <nav class="mx-auto flex max-w-7xl items-center justify-between p-6 lg:px-8" aria-label="Global">
    <div class="flex lg:flex-1">
      <a href="/" class="-m-1.5 p-1.5 flex items-center">
        <%=image_tag 'logo-linear.svg', class: "h-8", width: "45", height: "32", alt: "logo" %>
        <span class="ml-2 text-2xl text-white font-semibold">RUBY<b>CI</b> Test 9</span>
      </a>
    </div>
    <div class="flex lg:hidden">
      <button id="mobileMenuButton" type="button" class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-gray-400">
        <span class="sr-only">Open main menu</span>
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" data-slot="icon">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
    <div class="hidden lg:flex lg:items-center lg:gap-x-12">
      <a href="/docs" class="text-base leading-normal text-white hover:text-[#a3a3a3]">Docs</a>
      <a href="/features" class="text-base leading-normal text-white hover:text-[#a3a3a3]">Features</a>
      <a href="/pricing" class="text-base leading-normal text-white hover:text-[#a3a3a3]">Pricing</a>
      <a href="/circle_ci" class="text-base leading-normal text-white hover:text-[#a3a3a3]">RubyCI vs CircleCI</a>
      <div class="relative">
        <button type="button" id="dropdownButton" class="flex items-center gap-x-1 text-base leading-normal text-white hover:text-[#a3a3a3]" aria-expanded="false" aria-label="Dropdown button">
        </button>
        <div id="flyoutMenu" class="absolute -left-10 top-full w-screen max-w-44 z-40 mt-6 hidden">
          <div class="group relative flex gap-x-6 text-sm leading-5 rounded-t-md border border-b-0 border-slate-800 bg-slate-950 hover:bg-slate-900">
            <div class="flex-auto">
              <a href="/docs" class="p-4 block text-white">
                Support
              </a>
            </div>
          </div>
          <div class="group relative flex gap-x-6 text-sm leading-5 border border-b-0 border-slate-800 bg-slate-950 hover:bg-slate-900">
            <div class="flex-auto">
              <a href="/docs" class="p-4 block text-white">
                Documentation
              </a>
            </div>
          </div>
        <!--   <div class="group relative flex gap-x-6 text-sm leading-5 rounded-b-md border border-slate-800 bg-slate-950 hover:bg-slate-900">
            <div class="flex-auto">
              <a href="/blog" class="p-4 block text-white">
                Blog
              </a>
            </div>
          </div> -->
        </div>
      </div>
      <a href="https://cal.com/neshaz/rubyci-setup" class="js-book-call rounded-full ring-1 ring-inset ring-zinc-700 py-1 px-3 leading-normal text-white hover:text-[#a3a3a3] hover:ring-[#a3a3a3]" target="_blank">Book A Call</a>
    </div>
    <div class="hidden lg:flex lg:flex-1 lg:justify-end">
      <a href="https://app.ruby.ci/users/auth/github" class="inline-flex items-center gap-x-2 rounded-full px-4 py-1 text-base text-white shadow-sm ring-1 ring-inset ring-gray-300 hover:opacity-70">
        Login with
        <%= image_tag 'github.svg', class: '-mr-0.5 h-5 w-5', alt: "GitHub" %>
      </a>
    </div>
  </nav>
  <!-- Mobile menu, show/hide based on menu open state. -->
  <div id="mobileMenu" class="lg:hidden hidden" role="dialog" aria-modal="true">
    <!-- Background backdrop, show/hide based on slide-over state. -->
    <div class="fixed inset-0 z-40"></div>
    <div class="fixed inset-y-0 right-0 z-40 w-full overflow-y-auto bg-gray-950 px-6 py-6 sm:max-w-sm sm:ring-1 sm:ring-white/10">
      <div class="flex items-center justify-between">
        <a href="/" class="-m-1.5 p-1.5">
          <span class="sr-only">Your Company</span>
          <%= image_tag 'logo-rubyci-new.png', class: 'h-8 w-auto', alt: "" %>
        </a>
        <button id="closeMobileMenu" type="button" class="-m-2.5 rounded-md p-2.5 text-gray-400">
          <span class="sr-only">Close menu</span>
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" data-slot="icon">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="mt-6 flow-root">
        <div class="-my-6 divide-y divide-gray-500/25">
          <div class="space-y-2 py-6">
            <a href="/docs" class="-mx-3 block rounded-lg px-3 py-2 text-base leading-7 text-white hover:bg-gray-800">Docs</a>
            <a href="/features" class="-mx-3 block rounded-lg px-3 py-2 text-base leading-7 text-white hover:bg-gray-800">Features</a>
            <a href="/pricing" class="-mx-3 block rounded-lg px-3 py-2 text-base leading-7 text-white hover:bg-gray-800">Pricing</a>
            <a href="/circle_ci" class="-mx-3 block rounded-lg px-3 py-2 text-base leading-7 text-white hover:bg-gray-800">RubyCI vs CircleCI</a>
            <!-- <a href="/blog" class="-mx-3 block rounded-lg px-3 py-2 text-base leading-7 text-white hover:bg-gray-800">Blogs</a> -->
            <div class="-mx-3">
              <div class="mt-2 space-y-2 hidden" id="disclosure-1">
                <a href="/docs" class="block rounded-lg py-2 pl-6 pr-3 text-sm leading-7 text-white hover:bg-slate-800">Support</a>
                <a href="/docs" class="block rounded-lg py-2 pl-6 pr-3 text-sm leading-7 text-white hover:bg-slate-800">Documentation</a>
                <!-- <a href="/blog" class="block rounded-lg py-2 pl-6 pr-3 text-sm leading-7 text-white hover:bg-slate-800">Blog</a> -->
              </div>
            </div>
            <a href="https://cal.com/neshaz/rubyci-setup" class="js-book-call -mx-3 block rounded-lg px-3 py-2 text-base leading-7 text-white hover:bg-gray-800" target="_blank">Book A Call</a>
          </div>
          <div class="py-6">
            <a href="https://app.ruby.ci/users/auth/github" class="-mx-3 block rounded-lg px-3 py-2.5 text-base leading-7 text-white hover:bg-gray-800">Log in</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
