<main class="bg-gradient-to-b from-slate-900 to-gray-950">
  <section id="features-hero-section">
    <div class="relative overflow-hidden -mb-1 bg-slate-950">
      <div class="mx-auto max-w-7xl px-6 mt-16 lg:flex lg:px-8">
        <div class="mx-auto max-w-2xl flex-shrink-0 lg:mx-0 lg:max-w-xl lg:pt-8 z-10">
          <h1 class="text-4xl font-normal tracking-tight text-white sm:text-5xl">Committer Analysis provides a comprehensive view of all contributors in one place</h1>
          <ul class="space-y-4 pt-6">
            <li class="text-white flex text-lg font-normal items-start">
              <p>Collaborative feature for tracking productivity and code quality - analysis of every committer.</p>
            </li>
            <li class="text-white flex text-lg font-normal items-start">
              <p>Managers and CTOs gain better control over the development process, enabling data-driven decisions to enhance overall efficiency.</p>
            </li>
            <li class="text-white flex text-lg font-normal items-start">
              <p>It ensures cleaner code and a healthier application by tracking individual commit trends and performance.</p>
            </li>
          </ul>
        </div>
        <div class="relative mx-auto mt-16 flex max-w-2xl sm:mt-24 lg:ml-10 lg:mr-0 lg:mt-0 lg:max-w-none lg:flex-none xl:ml-32">
          <div class="max-w-3xl flex-none sm:max-w-5xl lg:max-w-none max-h-fit">
            <%= image_tag 'hero-features-image.webp', class: 'max-h-[85%]', alt: "App screenshot" %>
          </div>
        </div>
      </div>
    </div>
  </section>
