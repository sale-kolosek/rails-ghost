<!DOCTYPE html>
<html lang="<%= @settings['lang'] %>">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= @settings['meta_description'].present? ? @settings['meta_description'] : 'Software development company that specializes in designing and developing custom web and mobile applications, and creating beautiful UX designs' %>">
    <meta name="keywords" content="web development, mobile development, UX designs, quality code">
    <title><%= @settings['meta_title'].present? ? @settings['meta_title'] : 'Kolosek | Ruby on Rails development company' %></title>

    <%= favicon_link_tag 'kolosek/favicon.svg' %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="canonical" href="https://kolosek.com" />

    <%= stylesheet_link_tag '/css/kolosek.css', media: 'all', "data-turbo-track": "reload" %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js" integrity="sha384-ENjdO4Dr2bkBIFxQpeoTz1HIcje39Wm4jDKdf19U8gI4ddQ3GYNS7NTKfAdVQSZe" crossorigin="anonymous"></script>

    <%= raw @settings['codeinjection_head'] %>
  </head>

  <body class="home-template is-head-left-logo has-cover">
    <div class="viewport">
      <div class="site-content">
        <%= yield %>
      </div>
    </div>
    <%= raw @settings['codeinjection_foot'] %>

    <script
      src="https://code.jquery.com/jquery-3.5.1.min.js"
      integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0="
      crossorigin="anonymous">
    </script>

    <script>
      $(document).ready(function () {
          // Mobile Menu Trigger
          $('.gh-burger').click(function () {
              $('body').toggleClass('gh-head-open');
          });
          // FitVids - Makes video embeds responsive
          $(".gh-content").fitVids();
      });
    </script>
  </body>
</html>
