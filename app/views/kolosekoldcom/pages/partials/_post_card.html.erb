<div class="col-12 col-md-6 col-lg-4">
  <div class="card d-block">
    <% if post['primary_tag'].present? %>
      <div class="card-header">
        <%= post['primary_tag']['name'] %>
      </div>
    <% end %>
    <div class="card-body">
      <a href="<%= post['slug'] %>" style="text-decoration: none;">
        <h3 class="card-title"><%= post['title'] %></h3>
      </a>
      <a href="<%= post['slug'] %>" style="text-decoration: none;">
        <p class="card-text">
          <%= post['excerpt'] %>
        </p>
      </a>
    </div>
    <div class="card-footer">
      <img src="<%= post['primary_author']['profile_image'] %>" class="rounded-circle" style="width: 40px; height: 40px;" alt="">
      <p>
        <% if post['published_at'].present? %>
          <span><%= post['published_at'].to_datetime.strftime("MMMM D, YYYY") %></span>
        <% end %>
        <% if post['reading_time'].present? %>
          <span><%= post['reading_time'] %>  min read</span>
        <% end %>
      </p>
    </div>
  </div>
</div>
