<!-- ========== HERO ========== -->
<section class="lr-hero lr-hero-about lr-fade-in" style="padding: 80px 0 40px;">
  <div class="container">
    <h1>Get in <span>touch</span></h1>
  </div>
</section>

<!-- ========== CONTACT SECTION ========== -->
<section class="lr-section lr-fade-in" style="padding-top: 40px;">
  <div class="container">
    <div class="lr-contact-grid">
      <!-- Left: Native contact form -->
      <div class="lr-contact-form-card">
        <div id="form_response">
        <%= form_with url: forms_path, method: :post, class: "lr-native-form" do |f| %>
          <input type="hidden" name="form[form_type]" value="contact">
          <div class="lr-form-row">
            <div class="lr-form-group">
              <label for="first_name" class="lr-form-label">First Name</label>
              <input type="text" id="first_name" name="first_name" required class="lr-form-input" placeholder="John">
            </div>
            <div class="lr-form-group">
              <label for="last_name" class="lr-form-label">Last Name</label>
              <input type="text" id="last_name" name="last_name" required class="lr-form-input" placeholder="Doe">
            </div>
          </div>
          <div class="lr-form-group">
            <label for="form_email" class="lr-form-label">Email</label>
            <input type="email" id="form_email" name="form[email]" required class="lr-form-input" placeholder="john@example.com">
          </div>
          <div class="lr-form-group">
            <label for="project_name" class="lr-form-label">Project Name</label>
            <input type="text" id="project_name" name="project_name" class="lr-form-input" placeholder="My awesome project">
          </div>
          <div class="lr-form-group">
            <label for="message" class="lr-form-label">Message</label>
            <textarea id="message" name="message" rows="5" required class="lr-form-textarea" placeholder="Tell us about your project, goals, and timeline..."></textarea>
          </div>
          <input type="hidden" name="form[name]" id="form_name_hidden">
          <input type="hidden" name="form[data][project_name]" id="form_data_project_name">
          <input type="hidden" name="form[data][message]" id="form_data_message">
          <button type="submit" class="lr-btn lr-btn-primary lr-btn-lg lr-form-submit" data-umami-event="contact-form-submit" onclick="document.getElementById('form_name_hidden').value = document.getElementById('first_name').value + ' ' + document.getElementById('last_name').value; document.getElementById('form_data_project_name').value = document.getElementById('project_name').value; document.getElementById('form_data_message').value = document.getElementById('message').value;">
            Send message
            <svg viewBox="0 0 16 16" fill="none"><path d="M3.33 8h9.34M8.67 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        <% end %>
        </div>
      </div>

      <!-- Right: Get in touch info -->
      <div class="lr-contact-info">
        <p class="lr-section-desc">We'd love to hear about your project. Whether you need a full AI product, a quick prototype, or expert guidance, we're here to help.</p>

        <div class="lr-contact-items">
          <div class="lr-contact-item">
            <div class="lr-value-icon">
              <svg viewBox="0 0 24 24" fill="none"><path d="M15.05 5A5 5 0 0119 8.95M15.05 1A9 9 0 0123 8.94M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div>
              <h3>Schedule a call</h3>
              <p>Book a free intro call to discuss your idea and see how we can help.</p>
              <a href="https://cal.com/neshaz/intro" target="_blank" class="lr-contact-link" data-umami-event="cta-schedule-call">
                Book a meeting
                <svg viewBox="0 0 16 16" fill="none"><path d="M4 12l8-8M6 4h6v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          </div>

          <div class="lr-contact-item">
            <div class="lr-value-icon">
              <svg viewBox="0 0 24 24" fill="none"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M22 6l-10 7L2 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div>
              <h3>Email us</h3>
              <p>Prefer to write? Drop us a line and we'll get back to you within 24 hours.</p>
              <a href="mailto:hello@kolosek.com" class="lr-contact-link">
                hello@kolosek.com
                <svg viewBox="0 0 16 16" fill="none"><path d="M4 12l8-8M6 4h6v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          </div>

          <div class="lr-contact-item">
            <div class="lr-value-icon">
              <svg viewBox="0 0 24 24" fill="none"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="2"/></svg>
            </div>
            <div>
              <h3>Visit us</h3>
              <p>Based in Novi Sad, Serbia. Working with clients worldwide across all time zones.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ========== CTA ========== -->
<section class="lr-cta lr-fade-in">
  <div class="container">
    <h2>Ready to build something<br><span>intelligent together?</span></h2>
    <a href="https://cal.com/neshaz/intro" target="_blank" class="lr-btn lr-btn-primary lr-btn-lg" data-umami-event="cta-schedule-call">
      Schedule a call
      <svg viewBox="0 0 16 16" fill="none"><path d="M3.33 8h9.34M8.67 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </div>
</section>
