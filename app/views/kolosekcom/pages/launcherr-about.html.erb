<!-- ========== HERO ========== -->
<section class="lr-hero lr-hero-about lr-fade-in">
  <div class="lr-hero-bg-nodes">
    <span></span><span></span><span></span><span></span><span></span>
    <span></span><span></span><span></span><span></span><span></span>
    <span></span><span></span><span></span><span></span>
  </div>
  <div class="container">
    <div class="lr-hero-tag">
      <svg viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      About Kolosek
    </div>
    <h1>We are <span>Kolosek</span></h1>
    <p>An AI-native agency of senior engineers building intelligent software that transforms businesses.</p>
  </div>
</section>

<!-- ========== MISSION ========== -->
<section class="lr-section lr-section-bordered lr-fade-in">
  <div class="container">
    <div class="lr-section-header lr-section-header-center">
      <div class="lr-section-tag">
        <svg viewBox="0 0 24 24" fill="none" style="width:14px;height:14px;"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Our mission
      </div>
      <h2 class="lr-section-heading">Building software that<br><span>thinks for itself</span></h2>
      <p class="lr-section-desc">We exist to help businesses harness the power of AI. Not as a buzzword, but as a core part of the products we build. Every line of code we write is designed to make your business smarter, faster, and more efficient.</p>
    </div>
  </div>
</section>

<!-- ========== STATS ========== -->
<section class="lr-section lr-section-bordered lr-fade-in">
  <div class="container">
    <div class="lr-about-stats lr-stagger">
      <div class="lr-about-stat lr-stagger-item">
        <h3>15+</h3>
        <p>Years of experience</p>
      </div>
      <div class="lr-about-stat lr-stagger-item">
        <h3>200+</h3>
        <p>Projects shipped</p>
      </div>
      <div class="lr-about-stat lr-stagger-item">
        <h3>50+</h3>
        <p>AI projects delivered</p>
      </div>
      <div class="lr-about-stat lr-stagger-item">
        <h3>30+</h3>
        <p>Team members</p>
      </div>
    </div>
  </div>
</section>

<!-- ========== STORY ========== -->
<section class="lr-section lr-section-bordered lr-fade-in">
  <div class="container">
    <div class="lr-about-story">
      <div class="lr-about-story-text">
        <div class="lr-section-tag">
          <svg viewBox="0 0 24 24" fill="none" style="width:14px;height:14px;"><path d="M12 20V10M18 20V4M6 20v-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Our story
        </div>
        <h2 class="lr-section-heading">From consultancy<br><span>to AI-native agency</span></h2>
        <p class="lr-section-desc">We started as a software consultancy, helping startups and enterprises build reliable, scalable products with Ruby on Rails and React. Over the years, we shipped hundreds of projects across industries, earning a reputation for quality and speed.</p>
        <p class="lr-section-desc" style="margin-top: 16px;">When the AI revolution arrived, we didn't just add it to our services list. We went all in. We rebuilt our workflows, retrained our team, and redesigned how we approach every project. Today, AI is embedded in everything we do, from how we write code to the products we deliver.</p>
      </div>
      <div class="lr-about-story-visual">
        <div class="lr-about-timeline">
          <div class="lr-about-timeline-item">
            <div class="lr-about-timeline-dot"></div>
            <div class="lr-about-timeline-content">
              <h4>2011</h4>
              <p>Founded as a Rails consultancy in Novi Sad, Serbia</p>
            </div>
          </div>
          <div class="lr-about-timeline-item">
            <div class="lr-about-timeline-dot"></div>
            <div class="lr-about-timeline-content">
              <h4>2018</h4>
              <p>Expanded to full-stack with React, Python, and cloud-native</p>
            </div>
          </div>
          <div class="lr-about-timeline-item">
            <div class="lr-about-timeline-dot"></div>
            <div class="lr-about-timeline-content">
              <h4>2023</h4>
              <p>Pivoted to AI-native development with LLM integrations</p>
            </div>
          </div>
          <div class="lr-about-timeline-item">
            <div class="lr-about-timeline-dot"></div>
            <div class="lr-about-timeline-content">
              <h4>Today</h4>
              <p>A full AI-native agency shipping intelligent products worldwide</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ========== TEAM / CULTURE ========== -->
<section class="lr-section lr-section-bordered lr-fade-in">
  <div class="container">
    <div class="lr-section-header lr-section-header-center">
      <div class="lr-section-tag">
        <svg viewBox="0 0 24 24" fill="none" style="width:14px;height:14px;"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Our team
      </div>
      <h2 class="lr-section-heading">Senior engineers who<br><span>live and breathe AI</span></h2>
      <p class="lr-section-desc">No juniors, no outsourcing. Every person on your project is a seasoned engineer with hands-on AI experience. We're a tight-knit team that ships fast and takes ownership.</p>
    </div>
    <div class="lr-value-grid lr-stagger">
      <div class="lr-value-card lr-stagger-item">
        <div class="lr-value-icon">
          <svg viewBox="0 0 24 24" fill="none"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M22 4L12 14.01l-3-3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3>Deep AI Expertise</h3>
        <p>Our engineers work daily with LLMs, RAG systems, fine-tuning, and production ML pipelines. AI isn't a side skill, it's our core competency.</p>
      </div>
      <div class="lr-value-card lr-stagger-item">
        <div class="lr-value-icon">
          <svg viewBox="0 0 24 24" fill="none"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </div>
        <h3>Full-Stack Builders</h3>
        <p>From database schema to UI polish, our engineers handle the entire stack. No handoffs, no gaps, no excuses.</p>
      </div>
      <div class="lr-value-card lr-stagger-item">
        <div class="lr-value-icon">
          <svg viewBox="0 0 24 24" fill="none"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3>Direct Communication</h3>
        <p>You talk directly to the engineers building your product. No project managers playing telephone, no unnecessary layers.</p>
      </div>
    </div>
  </div>
</section>

