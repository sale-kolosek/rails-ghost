<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>
    <%= content_for?(:title) ? yield(:title) : "Kolosek | Native AI Agency" %>
  </title>
  <meta name="description" content="<%= @settings['meta_description'].present? ? @settings['meta_description'] : 'We build AI-powered products natively. From custom AI agents to full-stack development, Kolosek delivers intelligent software from concept to production.' %>">
  <%= csrf_meta_tags %>

  <%= favicon_link_tag 'kolosek/favicon.svg' %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/files/kolosekcom.css">
  <%= stylesheet_link_tag '/css/ghost.min.css', media: 'all', "data-turbo-track": "reload" %>
  <script type="module" src="https://cdn.jsdelivr.net/npm/@hotwired/turbo@8.0.17/dist/turbo.es2017-esm.min.js"></script>
  <%= raw @settings['codeinjection_head'] %>

  <%= raw @header_script if @header_script.present? %>
</head>
<body>
  <%= render "kolosekcom/partials/header" %>
  <%= render "shared/flash" %>
  <%= yield %>
  <%= render "kolosekcom/partials/footer" %>

  <script src="/files/kolosekcom.js"></script>
  <%= raw @settings['codeinjection_foot'] %>
  <%= raw @footer_script if @footer_script.present? %>
</body>
</html>
