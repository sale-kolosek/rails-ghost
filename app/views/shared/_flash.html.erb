<% flash_colors = { "alert" => "#e53e3e", "error" => "#e53e3e", "notice" => "#38a169", "success" => "#38a169", "info" => "#3182ce" } %>
<% flash.each do |type, message| %>
  <div style="padding: 12px 20px; margin: 0; text-align: center; color: white; font-family: sans-serif; font-size: 14px; background-color: <%= flash_colors[type] || '#3182ce' %>;">
    <%= message %>
  </div>
<% end %>
