<main>
  <section id="hero-section" class="relative px-6 pt-14 lg:px-8 opacity-0 animate-fade-in">
    <div class="mx-auto max-w-4xl py-16 sm:pt-24">
      <div class="hidden sm:mb-8 sm:flex sm:justify-center">
        <div class="animate-background rounded-full bg-gradient-to-r from-green-300 via-blue-600 to-red-300 bg-[length:_400%_400%] px-px py-1 [animation-duration:_6s]">
          <a href="https://app.litetracker.com/" class="relative rounded-full bg-white px-3 py-1.5 text-sm/6 text-gray-600">
            <span class="inline-flex items-center rounded-full bg-green-50 px-2 py-1 text-xs font-medium text-green-700 inset-ring inset-ring-green-600/20">NEW</span>
            <span class="pl-2">Automatic import from Jira, Trello, and many more  (08/2025)</span>
          </a>
        </div>
      </div>
      <div class="text-center">
        <h1 class="text-5xl font-medium tracking-tight text-balance text-gray-900 sm:text-7xl">The most complete Pivotal Tracker successor*</h1>
        <p class="mt-8 mx-auto max-w-2xl text-subheading">Packed with features we all love. Easy 1 minute transfer and complementary onboarding when you book a call.</p>
        <div class="mt-10 flex items-center justify-center gap-x-6">
          <a href="https://app.litetracker.com" class="rounded-xl bg-black px-5 py-3 text-base font-semibold text-white shadow-xs hover:bg-black/80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-black/80">Get started &rightarrow;</a>
          <a href="#" class="rounded-xl border border-gray-200 px-5 py-3 shadow-xs text-base font-semibold text-gray-900 hover:bg-gray-100">Learn more <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </div>
    <div class="max-w-7xl min-w-auto mx-auto flex justify-center pb-6">
      <div class="relative">
        <%= image_tag 'litetracker/hero-image.avif', width: "2880", height: "1606", class: "w-full h-full rounded-md bg-white/5 shadow-2xl ring-1 ring-white/10 object-cover object-[left_center]" %>
        <p class="absolute -bottom-10 w-full text-center text-base font-medium text-gray-500">Trusted by the ex Pivots and thousands of users</p>
      </div>
    </div>
  </section>

  <section id="features-section" class="relative px-6 pt-14 lg:px-8">
    <div class="relative mx-auto max-w-7xl py-16 sm:pt-24 flex items-center flex-col justify-start gap-y-24 w-full">
      <div class="mx-auto max-w-2xl flex flex-col gap-y-6 justify-center w-full text-center">
        <div class="flex items-center justify-center text-blue-dark text-xs">
          <svg class="h-4 w-4"  fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
          <p class="pl-1 font-bold">Seamless collaboration</p>
        </div>
        <h3 class="text-heading">
          Most Features We Loved in Pivotal Tracker
        </h3>
        <p class="text-subheading">Features</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 justify-center gap-10">
        <!-- card 1 -->
        <div class="w-full">
          <div class="flex flex-col gap-y-8">
            <div class="rounded-4xl shadow-xl bg-white h-100">
              <%= image_tag 'litetracker/feature-story-details.avif', class: "rounded-4xl w-full h-full object-center object-contain", alt: '' %>
            </div>
            <div class="flex flex-col gap-4 w-full text-sm">
              <div class="flex flex-col gap-2">
                <p class="text-[#020a0f] font-medium">Story details</p>
                <p class="text-[#47474f] font-normal">Manage requesters, owners, reviews. Chnage story type and add points on the fly.</p>
              </div>
              <a href="/pricing.html" class="flex items-center text-black font-semibold">
                <span>Learn more</span>
                <svg class="h-4"  width="24" height="24" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z"/>
                  <polyline points="9 6 15 12 9 18" />
                </svg>
              </a>
            </div>
          </div>
        </div>
        <!-- card 2 -->
        <div class="w-full">
          <div class="flex flex-col gap-y-8">
            <div class="rounded-4xl shadow-xl bg-white h-100">
              <%= image_tag 'litetracker/feature-manage-stories.avif', class: "rounded-4xl w-full h-full object-center object-contain", alt: '' %>
            </div>
            <div class="flex flex-col gap-4 w-full text-sm">
              <div class="flex flex-col gap-2">
                <p class="text-[#020a0f] font-medium">Manage stories</p>
                <p class="text-[#47474f] font-normal">The backlog contains prioritized tasks, while the icebox is used for ideas or tasks that are not currently a priority.</p>
              </div>
              <a href="/pricing.html" class="flex items-center text-black font-semibold">
                <span>Learn more</span>
                <svg class="h-4"  width="24" height="24" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z"/>
                  <polyline points="9 6 15 12 9 18" />
                </svg>
              </a>
            </div>
          </div>
        </div>
        <!-- card 3 -->
        <div class="w-full">
          <div class="flex flex-col gap-y-8">
            <div class="rounded-4xl shadow-xl bg-white h-100">
              <%= image_tag 'litetracker/feature-instant-feedback.avif', class: "rounded-4xl w-full h-full object-center object-contain", alt: '' %>
            </div>
            <div class="flex flex-col gap-4 w-full text-sm">
              <div class="flex flex-col gap-2">
                <p class="text-[#020a0f] font-medium">Instant feedback</p>
                <p class="text-[#47474f] font-normal">Get notifications as soon as they occur. In email and in-app notifications.</p>
              </div>
              <a href="/pricing.html" class="flex items-center text-black font-semibold">
                <span>Learn more</span>
                <svg class="h-4"  width="24" height="24" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z"/>
                  <polyline points="9 6 15 12 9 18" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="features-epics-section" class="relative px-6 pt-14 lg:px-8">
    <div class="relative mx-auto max-w-7xl py-16 sm:pt-24">
      <div class="mx-auto max-w-7xl md:px-6 lg:px-8">
        <div class="grid grid-cols-1 gap-x-36 gap-y-16 sm:gap-y-20 lg:grid-cols-2 lg:content-start">
          <div class="flex flex-col gap-10 px-6 lg:px-0">
            <div class="flex flex-col gap-4">
              <p class="flex items-center gap-1 text-orange font-semibold text-sm">
                <svg class="h-4 w-4"  width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z"/>
                  <rect x="4" y="5" width="16" height="16" rx="2" />
                  <line x1="16" y1="3" x2="16" y2="7" />
                  <line x1="8" y1="3" x2="8" y2="7" />
                  <line x1="4" y1="11" x2="20" y2="11" />
                  <rect x="8" y="15" width="2" height="2" />
                </svg>
                Manage your Epics
              </p>
              <p class="text-heading tracking-tight text-black">Effective Planning</p>
              <ol class="space-y-3">
                <li class="text-subheading flex items-start">
                  Built-in velocity tracking was a favorite, using Fibonacci-scale story points to calculate team capacity as a rolling average (e.g., over the last four sprints).
                </li>
              </ol>
            </div>
            <div class="h-11 w-fit">
              <a href="/pricing.html" class="flex items-center justify-center rounded-xl h-full pr-4 pl-5 border border-gray-200 text-black font-semibold hover:bg-gray-100">
                <span>Learn more</span>
                <svg class="h-4"  width="24" height="24" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z"/>
                  <polyline points="9 6 15 12 9 18" />
                </svg>
              </a>
            </div>
          </div>
          <div class="sm:px-6 lg:px-0">
            <div class="relative px-6 sm:mx-auto sm:max-w-2xl sm:rounded-3xl sm:pl-0 sm:pr-0 lg:mx-0 lg:max-w-none">
              <div class="relative mx-auto w-full sm:mx-0">
                <%= image_tag 'litetracker/features-epics.avif', class: "w-full rounded-4xl", alt: '' %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="features-notification-section" class="relative px-6 pt-14 lg:px-8">
    <div class="relative mx-auto max-w-7xl py-16 sm:pt-24">
      <div class="mx-auto max-w-7xl md:px-6 lg:px-8">
        <div class="grid grid-cols-1 gap-x-36 gap-y-16 sm:gap-y-20 lg:grid-cols-2 lg:content-start">
          <div class="flex flex-col gap-10 px-6 lg:px-0 order-last">
            <div class="flex flex-col gap-4">
              <p class="flex items-center gap-1 text-purple font-semibold text-sm">
                <svg class="h-4 w-4"  width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z"/>
