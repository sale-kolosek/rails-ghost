                </svg>
                Easy notification
              </p>
              <p class="text-heading tracking-tight text-black">Collaboration and Team Alignment</p>
              <ol class="space-y-3">
                <li class="text-subheading flex items-start">
                  Bringing distributed teams together for real-time visibility, priority agreement, and focused collaboration
                </li>
              </ol>
            </div>
            <div class="h-11 w-fit">
              <a href="/pricing.html" class="flex items-center justify-center rounded-xl h-full pr-4 pl-5 border border-gray-200 text-black font-semibold hover:bg-gray-100">
                <span>Learn more</span>
                <svg class="h-4"  width="24" height="24" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z"/>
                  <polyline points="9 6 15 12 9 18" />
                </svg>
              </a>
            </div>
          </div>
          <div class="sm:px-6 lg:px-0">
            <div class="relative px-6 sm:mx-auto sm:max-w-2xl sm:rounded-3xl sm:pl-0 sm:pr-0 lg:mx-0 lg:max-w-none">
              <div class="relative mx-auto w-full sm:mx-0">
                <%= image_tag 'litetracker/features-notifications.avif', class: "w-full rounded-4xl", alt: '' %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-spacer">
    <div class="w-full h-60"></div>
  </section>

  <!-- to do - need bento grid template -->
  <section id="features-empower-workflow" class="relative px-6 pt-14 lg:px-8 bg-[#f6f6f8] shadow-[inset_0_2px_4px_-3px_#0003,inset_0_-2px_4px_-3px_#0003]">
    <div class="relative mx-auto max-w-7xl py-16 sm:pt-24 flex items-center flex-col justify-start gap-y-24 w-full">
      <div class="mx-auto max-w-2xl flex flex-col gap-y-6 justify-center w-full text-center">
        <div class="flex items-center justify-center text-green-dark text-xs">
          <svg class="h-4 w-4"  fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
          <p class="pl-1 font-bold">Features</p>
        </div>
        <h3 class="text-heading">
          Features designed to empower your workflow
        </h3>
        <p class="text-base font-normal text-gray-500 sm:text-lg/8">Stay ahead with tools that prioritize your needs, integrating insights and efficiency into one powerful platform.</p>
      </div>
    </div>
  </section>

  <section class="section-spacer">
    <div class="w-full h-60"></div>
  </section>

